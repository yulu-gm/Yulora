{
  "appId": "com.yulora.app",
  "afterPack": "./scripts/after-pack-win-icon.mjs",
  "electronLanguages": ["en-US", "zh-CN", "zh-TW"],
  "productName": "Yulora",
  "artifactName": "${productName}-Setup-${version}.${ext}",
  "directories": {
    "output": "release"
  },
  "extraResources": [
    {
      "from": "build/icons",
      "to": "icons"
    }
  ],
  "files": [
    "package.json",
    "dist/**/*",
    "dist-electron/**/*",
    "dist-cli/**/*",
    "!dist-electron/**/*.d.ts",
    "!dist-cli/**/*.map",
    "!src{,/**}",
    "!tests{,/**}",
    "!docs{,/**}",
    "!reports{,/**}",
    "!.artifacts{,/**}",
    "!fixtures{,/**}",
    "!tmp{,/**}"
  ],
  "win": {
    "icon": "build/icons/light/icon.ico",
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
