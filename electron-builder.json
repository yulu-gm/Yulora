{
  "appId": "com.fishmark.app",
  "electronVersion": "41.2.0",
  "electronLanguages": ["en-US", "zh-CN", "zh-TW"],
  "productName": "FishMark",
  "artifactName": "${productName}-Setup-${version}.${ext}",
  "electronUpdaterCompatibility": ">=2.16",
  "directories": {
    "output": "release"
  },
  "extraResources": [
    {
      "from": "build/icons",
      "to": "icons"
    }
  ],
  "files": [
    "package.json",
    "dist/**/*",
    "dist-electron/**/*",
    "!dist-electron/**/*.d.ts",
    "!src{,/**}",
    "!tests{,/**}",
    "!docs{,/**}",
    "!reports{,/**}",
    "!.artifacts{,/**}",
    "!fixtures{,/**}",
    "!tmp{,/**}"
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "yulu-gm",
      "repo": "FishMark",
      "releaseType": "release"
    }
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "icon": "build/icons/light/icon-512.png",
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      },
      {
        "target": "zip",
        "arch": ["arm64"]
      }
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "name": "Markdown Document",
        "role": "Editor"
      }
    ]
  },
  "win": {
    "icon": "build/icons/light/icon.ico",
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
